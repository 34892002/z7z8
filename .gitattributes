# set default behavior: all text files use LF line endings
* text=auto eol=lf

# declare binary files to prevent Git from modifying them
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.tar.gz binary
*.gz binary

# shell scripts must use LF
*.sh text eol=lf
*.bash text eol=lf

# text files use LF
*.txt text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# python scripts use LF
*.py text eol=lf

# config files use LF
*.conf text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env text eol=lf
